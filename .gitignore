*.bak
*.swp
*.swo
*~
.DS_Store
gnupg/.gnupg/*
!gnupg/.gnupg/gpg-agent.conf

# Per-host hyprland symlink created by `make host-link`.
# Lands here due to stow tree-folding `~/.config/hypr` to this dir.
hypr/.config/hypr/host.lua

# Quickshell runtime state (emoji recents, etc.)
quickshell/.config/quickshell/state/

# graphify output cache, left behind when /graphify runs with this repo as CWD.
# Never part of the dotfiles; graphify-sync.sh already skips it.
graphify-out/
