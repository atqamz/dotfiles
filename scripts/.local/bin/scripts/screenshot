#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1090
source "${BASH_COMMON:-$script_dir/bash-common}"

require_cmd grim
require_cmd slurp
require_cmd hyprpicker
require_cmd magick
require_cmd wl-copy

readonly VALID_MODES="smart region window fullscreen"
readonly VALID_PROCESSING="all copy save edit"

mode="smart"
processing="all"
editor_override=""
delay=0

for arg in "$@"; do
  case "$arg" in
    --editor=*) editor_override="${arg#--editor=}" ;;
    --delay=*) delay="${arg#--delay=}" ;;
    *)
      if [[ " $VALID_MODES " == *" $arg "* ]]; then
        mode="$arg"
      elif [[ " $VALID_PROCESSING " == *" $arg "* ]]; then
        processing="$arg"
      else
        printf 'unknown argument: %s\n' "$arg" >&2
        printf 'usage: screenshot [smart|region|window|fullscreen] [all|copy|save|edit] [--delay=N] [--editor=<name>]\n' >&2
        exit 1
      fi
      ;;
  esac
done

resolve_editor() {
  if [[ -n "$editor_override" ]]; then
    printf '%s' "$editor_override"
  elif [[ -n "${SCREENSHOT_EDITOR:-}" ]]; then
    printf '%s' "$SCREENSHOT_EDITOR"
  elif has_cmd satty; then
    printf 'satty'
  elif has_cmd swappy; then
    printf 'swappy'
  else
    printf ''
  fi
}

editor="$(resolve_editor)"
screenshot_dir="${SCREENSHOT_DIR:-${XDG_PICTURES_DIR:-$HOME/Pictures}/Screenshots}"

hyprpicker_pid=""
tmpfile=""

cleanup() {
  if [[ -n "$hyprpicker_pid" ]]; then
    kill "$hyprpicker_pid" 2>/dev/null || true
    wait "$hyprpicker_pid" 2>/dev/null || true
    hyprpicker_pid=""
  fi
  [[ -n "$tmpfile" ]] && rm -f "$tmpfile"
}

trap cleanup EXIT

pre_capture() {
  if ((delay > 0)); then
    sleep "$delay"
  fi
  tmpfile=$(mktemp --suffix=.png)
  grim -c "$tmpfile"
}

freeze_screen() {
  hyprpicker -r -z >/dev/null 2>&1 &
  hyprpicker_pid=$!
  sleep 0.2
}

unfreeze_screen() {
  if [[ -n "$hyprpicker_pid" ]]; then
    kill "$hyprpicker_pid" 2>/dev/null || true
    wait "$hyprpicker_pid" 2>/dev/null || true
    hyprpicker_pid=""
  fi
}

crop_and_output() {
  local geom="$1"
  local x y w h
  IFS=', x' read -r x y w h <<< "$geom"
  magick "$tmpfile" -crop "${w}x${h}+${x}+${y}" +repage png:-
}

get_window_rects() {
  hyprctl clients -j | jq -r '
    .[] | select(.mapped == true and .hidden == false) |
    "\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"
  '
}

get_active_monitor() {
  hyprctl monitors -j | jq -r '.[] | select(.focused == true) | .name'
}

snap_to_window() {
  local geom="$1"
  local x y w h area
  IFS=', x' read -r x y w h <<< "$geom"
  area=$((w * h))
  if ((area < 20)); then
    local cx=$((x + w / 2))
    local cy=$((y + h / 2))
    local best=""
    while IFS= read -r rect; do
      local rx ry rw rh
      IFS=', x' read -r rx ry rw rh <<< "$rect"
      if ((cx >= rx && cx < rx + rw && cy >= ry && cy < ry + rh)); then
        best="$rect"
      fi
    done <<< "$(get_window_rects)"
    if [[ -n "$best" ]]; then
      printf '%s' "$best"
      return
    fi
  fi
  printf '%s' "$geom"
}

capture_smart() {
  pre_capture
  freeze_screen
  local rects geometry
  rects="$(get_window_rects)"
  geometry="$(echo "$rects" | slurp)" || { unfreeze_screen; exit 1; }
  unfreeze_screen
  geometry="$(snap_to_window "$geometry")"
  crop_and_output "$geometry"
}

capture_region() {
  pre_capture
  freeze_screen
  local geometry
  geometry="$(slurp)" || { unfreeze_screen; exit 1; }
  unfreeze_screen
  crop_and_output "$geometry"
}

capture_window() {
  pre_capture
  freeze_screen
  local rects geometry
  rects="$(get_window_rects)"
  geometry="$(echo "$rects" | slurp -r)" || { unfreeze_screen; exit 1; }
  unfreeze_screen
  crop_and_output "$geometry"
}

capture_fullscreen() {
  local monitor
  monitor="$(get_active_monitor)"
  if ((delay > 0)); then
    sleep "$delay"
  fi
  grim -c -o "$monitor" -
}

generate_filepath() {
  local filename="Screenshot_$(date '+%Y-%m-%d_%H-%M-%S').png"
  mkdir -p "$screenshot_dir"
  printf '%s/%s' "$screenshot_dir" "$filename"
}

process_all() {
  local filepath
  filepath="$(generate_filepath)"
  tee "$filepath" | wl-copy --type image/png
  local filename
  filename="$(basename "$filepath")"
  if has_cmd notify-send; then
    (
      action="$(notify-send "Screenshot saved" "$filename" \
        --icon "$filepath" \
        --action "edit=Edit" 2>/dev/null || true)"
      if [[ "$action" == "edit" && -n "$editor" ]]; then
        "$editor" "$filepath"
      fi
    ) &
    disown
  fi
}

process_copy() {
  wl-copy --type image/png
}

process_save() {
  local filepath
  filepath="$(generate_filepath)"
  cat > "$filepath"
}

process_edit() {
  local file="$1"
  if [[ "$editor" == "satty" ]]; then
    satty --filename "$file" --copy-command "wl-copy --type image/png" --early-exit
  elif [[ "$editor" == "swappy" ]]; then
    swappy -f "$file"
    [[ -f "$file" ]] && wl-copy --type image/png < "$file"
  else
    wl-copy --type image/png < "$file"
  fi
}

capture() {
  case "$mode" in
    smart)      capture_smart      ;;
    region)     capture_region     ;;
    window)     capture_window     ;;
    fullscreen) capture_fullscreen ;;
  esac
}

if [[ "$processing" == "edit" ]]; then
  local_tmp=$(mktemp --suffix=.png)
  capture > "$local_tmp"
  process_edit "$local_tmp"
  rm -f "$local_tmp"
else
  capture | case "$processing" in
    all)  process_all  ;;
    copy) process_copy ;;
    save) process_save ;;
  esac
fi
