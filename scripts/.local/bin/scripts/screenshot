#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1090
source "${BASH_COMMON:-$script_dir/bash-common}"

require_cmd grim
require_cmd slurp
require_cmd hyprpicker
require_cmd wl-copy

readonly VALID_MODES="smart region window fullscreen"
readonly VALID_PROCESSING="all copy save"

mode="smart"
processing="all"
editor_override=""

for arg in "$@"; do
  case "$arg" in
    --editor=*) editor_override="${arg#--editor=}" ;;
    *)
      if [[ " $VALID_MODES " == *" $arg "* ]]; then
        mode="$arg"
      elif [[ " $VALID_PROCESSING " == *" $arg "* ]]; then
        processing="$arg"
      else
        printf 'unknown argument: %s\n' "$arg" >&2
        printf 'usage: screenshot [smart|region|window|fullscreen] [all|copy|save] [--editor=<name>]\n' >&2
        exit 1
      fi
      ;;
  esac
done

resolve_editor() {
  if [[ -n "$editor_override" ]]; then
    printf '%s' "$editor_override"
  elif [[ -n "${SCREENSHOT_EDITOR:-}" ]]; then
    printf '%s' "$SCREENSHOT_EDITOR"
  elif has_cmd satty; then
    printf 'satty'
  elif has_cmd swappy; then
    printf 'swappy'
  else
    printf ''
  fi
}

editor="$(resolve_editor)"
screenshot_dir="${SCREENSHOT_DIR:-${XDG_PICTURES_DIR:-$HOME/Pictures}/Screenshots}"

hyprpicker_pid=""

freeze_screen() {
  hyprpicker -r -z &
  hyprpicker_pid=$!
  sleep 0.2
}

unfreeze_screen() {
  if [[ -n "$hyprpicker_pid" ]]; then
    kill "$hyprpicker_pid" 2>/dev/null || true
    wait "$hyprpicker_pid" 2>/dev/null || true
    hyprpicker_pid=""
  fi
}

trap unfreeze_screen EXIT

get_window_rects() {
  hyprctl clients -j | jq -r '
    .[] | select(.mapped == true and .hidden == false) |
    "\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"
  '
}

get_active_monitor() {
  hyprctl monitors -j | jq -r '.[] | select(.focused == true) | .name'
}

snap_to_window() {
  local geom="$1"
  local x y w h area
  IFS=', x' read -r x y w h <<< "$geom"
  area=$((w * h))
  if ((area < 20)); then
    local cx=$((x + w / 2))
    local cy=$((y + h / 2))
    local best=""
    while IFS= read -r rect; do
      local rx ry rw rh
      IFS=', x' read -r rx ry rw rh <<< "$rect"
      if ((cx >= rx && cx < rx + rw && cy >= ry && cy < ry + rh)); then
        best="$rect"
      fi
    done <<< "$(get_window_rects)"
    if [[ -n "$best" ]]; then
      printf '%s' "$best"
      return
    fi
  fi
  printf '%s' "$geom"
}

capture_smart() {
  freeze_screen
  local rects geometry
  rects="$(get_window_rects)"
  geometry="$(echo "$rects" | slurp)" || { unfreeze_screen; exit 1; }
  unfreeze_screen
  geometry="$(snap_to_window "$geometry")"
  grim -g "$geometry" -
}

capture_region() {
  freeze_screen
  local geometry
  geometry="$(slurp)" || { unfreeze_screen; exit 1; }
  unfreeze_screen
  grim -g "$geometry" -
}

capture_window() {
  freeze_screen
  local rects geometry
  rects="$(get_window_rects)"
  geometry="$(echo "$rects" | slurp -r)" || { unfreeze_screen; exit 1; }
  unfreeze_screen
  grim -g "$geometry" -
}

capture_fullscreen() {
  local monitor
  monitor="$(get_active_monitor)"
  grim -o "$monitor" -
}
