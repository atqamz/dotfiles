#!/usr/bin/env bash
# shellcheck shell=bash
script_dir="$(dirname "$(readlink -f "$0")")"
source "${BASH_COMMON:-$script_dir/bash-common}"

if has_cmd cmatrix; then
  exec alacritty --class screensaver -e cmatrix -b -u 5
elif has_cmd cbonsai; then
  exec alacritty --class screensaver -e cbonsai -l -i
else
  printf 'no screensaver available (install cmatrix or cbonsai)\n' >&2
  exit 1
fi
