#!/usr/bin/env bash
# shellcheck shell=bash
script_dir="$(dirname "$(readlink -f "$0")")"
source "${BASH_COMMON:-$script_dir/bash-common}"

require_cmd hyprctl
require_cmd jq
require_cmd notify-send

SCALES=(1 1.25 1.5 2)

monitor_info=$(hyprctl monitors -j | jq -r '.[] | select(.focused == true)')
monitor_name=$(echo "$monitor_info" | jq -r '.name')
current_scale=$(echo "$monitor_info" | jq -r '.scale')
width=$(echo "$monitor_info" | jq -r '.width')
height=$(echo "$monitor_info" | jq -r '.height')
refresh=$(echo "$monitor_info" | jq -r '.refreshRate')

apply_scale() {
  # The lua config provider rejects `hyprctl keyword`; reconfigure the monitor by
  # evaluating hl.monitor() instead. The dispatcher wrapper prints a harmless
  # "expected a dispatcher" line after the call applies, so swallow all output.
  hyprctl dispatch "$(printf 'hl.monitor({output="%s", mode="%sx%s@%s", position="auto", scale=%s})' \
    "$monitor_name" "$width" "$height" "$refresh" "$1")" >/dev/null 2>&1 || true
}

if [ -n "$1" ] && [ "$1" != "cycle" ]; then
  apply_scale "$1"
  notify-send -u low "Display scaling: ${1}x"
  exit 0
fi

current_idx=0
best_diff=999
for i in "${!SCALES[@]}"; do
  diff=$(awk -v cur="$current_scale" -v s="${SCALES[$i]}" 'BEGIN { d = cur - s; if (d < 0) d = -d; print d }')
  if awk -v d="$diff" -v b="$best_diff" 'BEGIN { exit !(d < b) }'; then
    best_diff=$diff
    current_idx=$i
  fi
done

next_idx=$(( (current_idx + 1) % ${#SCALES[@]} ))
new_scale=${SCALES[$next_idx]}

apply_scale "$new_scale"
notify-send -u low "Display scaling: ${new_scale}x"
