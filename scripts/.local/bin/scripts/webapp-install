#!/usr/bin/env bash
# shellcheck shell=bash
script_dir="$(dirname "$(readlink -f "$0")")"
source "${BASH_COMMON:-$script_dir/bash-common}"

require_cmd notify-send

APPS_DIR="$HOME/.local/share/applications"
ICONS_DIR="$APPS_DIR/icons"
mkdir -p "$ICONS_DIR"

name="${1:-}"
url="${2:-}"
icon="${3:-}"

if [ -z "$name" ] || [ -z "$url" ]; then
  printf 'usage: webapp-install <name> <url> [icon-path]\n' >&2
  exit 1
fi

slug=$(echo "$name" | tr '[:upper:] ' '[:lower:]-')
desktop_file="$APPS_DIR/webapp-${slug}.desktop"

if [ -z "$icon" ]; then
  domain=$(echo "$url" | sed -E 's|https?://([^/]+).*|\1|')
  icon_path="$ICONS_DIR/webapp-${slug}.png"
  curl -sf "https://www.google.com/s2/favicons?domain=${domain}&sz=128" -o "$icon_path" 2>/dev/null || icon_path=""
else
  icon_path="$icon"
fi

browser=$(xdg-settings get default-web-browser 2>/dev/null | sed 's/\.desktop$//')

cat > "$desktop_file" << EOF
[Desktop Entry]
Name=$name
Exec=webapp-launch $url
Icon=${icon_path:-applications-internet}
Type=Application
Categories=Network;WebApps;
EOF

update-desktop-database "$APPS_DIR" 2>/dev/null
notify-send -u low "Web app installed: $name"
