#!/usr/bin/env bash
# shellcheck shell=bash
script_dir="$(dirname "$(readlink -f "$0")")"
source "${BASH_COMMON:-$script_dir/bash-common}"

require_cmd hyprctl

if toggle gaps-off status; then
  hyprctl keyword general:gaps_in 2 >/dev/null
  toggle gaps-off off
else
  hyprctl keyword general:gaps_in 0 >/dev/null
  toggle gaps-off on
fi
