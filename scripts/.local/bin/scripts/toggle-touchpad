#!/usr/bin/env bash
# shellcheck shell=bash
script_dir="$(dirname "$(readlink -f "$0")")"
source "${BASH_COMMON:-$script_dir/bash-common}"

require_cmd hyprctl
require_cmd jq
require_cmd notify-send

device=$(hyprctl devices -j | jq -r '.mice[] | select(.name | test("touchpad"; "i")) | .name' | head -n1)

if [ -z "$device" ]; then
  printf 'no touchpad device found\n' >&2
  exit 1
fi

action="${1:-toggle}"

# The lua config provider rejects `hyprctl keyword`; set device props by evaluating
# hl.device() instead. The dispatcher wrapper prints a harmless "expected a
# dispatcher" line after the call applies, so swallow all output.
dev_eval() { hyprctl dispatch "$(printf 'hl.device({name="%s", enabled=%s})' "$device" "$1")" >/dev/null 2>&1 || true; }

enable() {
  dev_eval true
  toggle touchpad-off off
  notify-send -u low "Touchpad enabled"
}

disable() {
  dev_eval false
  toggle touchpad-off on
  notify-send -u low "Touchpad disabled"
}

case "$action" in
  on) enable ;;
  off) disable ;;
  toggle)
    if toggle touchpad-off status; then
      enable
    else
      disable
    fi
    ;;
esac
