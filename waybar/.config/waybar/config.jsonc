{
  "layer": "top",
  "position": "bottom",
  "output": [
    "eDP-1"
  ],
  "height": 30,
  "margin": "4 10 0",
  "modules-left": [
    "clock",
    "hyprland/workspaces",
    "hyprland/window"
  ],
  "modules-center": [
    "custom/cpu_status",
    "custom/gpu_status",
    "memory"
  ],
  "modules-right": [
    "custom/claude_usage",
    "network",
    "backlight",
    "pulseaudio",
    "battery",
    "tray",
    "custom/notifications"
  ],
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}",
    "format-icons": {
      "default": "´äî",
      "focused": "´äæ",
      "urgent": "´ü¬"
    }
  },
  "hyprland/window": {
    "max-length": 48,
    "format": "{title}"
  },
  "clock": {
    "interval": 1,
    "format": "{:%d/%m/%Y %H:%M}",
    "tooltip-format": "{:%A, %d %B %Y %H:%M:%S}"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "´æª mute",
    "scroll-step": 3,
    "on-click": "pavucontrol",
    "format-icons": {
      "default": ["´Çª", "´Çº", "´Ç¿"]
    }
  },
  "custom/cpu_status": {
    "exec": "~/.local/bin/scripts/waybar-cpustatus",
    "return-type": "json",
    "interval": 5
  },
  "custom/claude_usage": {
    "exec": "~/.local/bin/scripts/waybar-claude-usage",
    "return-type": "json",
    "interval": 600,
    "tooltip": true
  },
  "custom/gpu_status": {
    "exec": "~/.local/bin/scripts/waybar-gpustatus",
    "return-type": "json",
    "interval": 5
  },
  "network": {
    "format-wifi": "´ç½ {signalStrength}%",
    "format-ethernet": "´×û {ifname}",
    "format-disconnected": "´ü▒ offline",
    "tooltip": true,
    "tooltip-format": "´ç½ {essid} {signalStrength}%\n{ipaddr}",
    "on-click": "kitty nmtui"
  },
  "backlight": {
    "format": "¾░âƒ {percent}%",
    "tooltip": false,
    "on-scroll-up": "brightnessctl set 5%+",
    "on-scroll-down": "brightnessctl set 5%-"
  },
  "memory": {
    "interval": 5,
    "format": "{icon}  {percentage}%",
    "format-alt": "RAM {used:0.1f}G/{total:0.1f}G",
    "format-alt-click": "click-right",
    "tooltip-format": "RAM {used:0.1f}G/{total:0.1f}G",
    "format-icons": ["´ö©"]
  },
  "custom/notifications": {
    "exec": "swaync-client -swb",
    "return-type": "json",
    "format": "{icon} {text}",
    "format-icons": {
      "none": "¾░éÜ",
      "notification": "¾░éÜ",
      "dnd-none": "¾░éø",
      "dnd-notification": "¾░éø"
    },
    "tooltip": false,
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "on-click-middle": "swaync-client -D -sw"
  },
  "battery": {
    "states": {
      "warning": 25,
      "critical": 10
    },
    "format": "{icon} {capacity}%",
    "format-charging": "´âº {capacity}%",
    "format-plugged": "´âº {capacity}%",
    "format-alt": "{time}",
    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
  },
  "tray": {
    "spacing": 10
  }
}
